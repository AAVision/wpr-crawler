# MongoDB
MONGO_URI=mongodb://admin:admin123@mongodb:27017
MONGO_DB=workplace_relations
MONGO_LANDING_COLLECTION=landing_documents
MONGO_TRANSFORMED_COLLECTION=transformed_documents

# MinIO (quay.io/minio/minio)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_LANDING_BUCKET=landing-zone
MINIO_TRANSFORMED_BUCKET=transformed-zone

# Scraping
PARTITION_SIZE_MONTHS=1
CONCURRENT_REQUESTS=8
REQUEST_DELAY=2.0
RETRY_TIMES=3
DOWNLOAD_TIMEOUT=60

# Proxy (optional)
PROXY_ENABLED=false
PROXY_URL=http://user:pass@proxy:port

# Logging
LOG_LEVEL=INFO
LOG_JSON_FORMAT=true